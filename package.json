{
  "name": "sluggenerator",
  "version": "1.0.0",
  "description": "a simple library for modern consumer to generate clean slugs.",
  "exports": {
    ".": {
      "default": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
